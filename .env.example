# Google Gemini API key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# LangSmith observability (optional but recommended for portfolio)
# Sign up at: https://smith.langchain.com
# Note: env var names changed in langsmith 0.8.x (LANGSMITH_* not LANGCHAIN_*)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-financial-analyst

# Tavily web search API (free tier: 1,000 credits/month)
# Sign up at: https://app.tavily.com/sign-in
TAVILY_API_KEY=your_tavily_api_key_here

# diskcache storage location (default: .cache in project root)
CACHE_DIR=.cache

# SQLite checkpoint database path (default: .checkpoints/state.db)
CHECKPOINT_DB_PATH=.checkpoints/state.db

# Budget tracking: estimated daily request limit (Gemini free tier)
GEMINI_DAILY_REQUEST_BUDGET=1500

