# ============================================================
# AI Financial Analyst Agent — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# --- Gemini API (required) ---
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Google OAuth (required for FastAPI backend + React frontend) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set Authorised JavaScript origins: http://localhost:5173
# Set Authorised redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_oauth_client_secret

# --- FastAPI JWT signing secret (required for backend) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FASTAPI_JWT_SECRET=change_me_to_a_random_32_byte_hex_string

# --- Database Setup (Supabase PostgreSQL) ---
# Create a free database at https://supabase.com
# Use the Direct Connection string (Transaction pooler + URI)
# IMPORTANT: If your password contains special characters like '?', '#', or '@', you MUST percent-encode them!
DATABASE_URL="postgresql+asyncpg://postgres.your_project_ref:[your-password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"

# --- LangSmith observability (optional but recommended for portfolio) ---
# https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-financial-analyst

# --- Tavily web search (free tier: 1,000 credits/month) ---
# https://app.tavily.com/sign-in
TAVILY_API_KEY=your_tavily_api_key_here

# --- Storage paths (defaults shown) ---
CACHE_DIR=.cache
CHECKPOINT_DB_PATH=.checkpoints/state.db
MEMORY_DB_PATH=.memory/memory.db

# --- Rate limits ---
GEMINI_DAILY_REQUEST_BUDGET=1500

# --- CORS (comma-separated origins allowed by FastAPI) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
